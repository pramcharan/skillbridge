    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register Freelancer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ram Kumar\",\n  \"email\": \"ram@test.com\",\n  \"password\": \"Password1!\",\n  \"role\": \"FREELANCER\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Token saved', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.token).to.be.a('string');",
            "  pm.collectionVariables.set('freelancerToken', j.token);",
            "});",
            "pm.test('Role is FREELANCER', () => pm.expect(pm.response.json().role).to.eql('FREELANCER'));",
            "pm.test('onboardingComplete is false', () => pm.expect(pm.response.json().onboardingComplete).to.be.false);"
          ]}}]
