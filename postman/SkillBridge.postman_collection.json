          ]}}]
        },
        {
          "name": "Login Client",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"priya@test.com\",\n  \"password\": \"Password1!\"\n}" }
