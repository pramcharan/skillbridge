    {
      "name": "5. Proposals",
      "item": [
        {
          "name": "Submit Proposal (Freelancer)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/proposals",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{freelancerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"jobId\": {{jobId}},\n  \"coverLetter\": \"I have 4 years of Spring Boot experience building production REST APIs with MySQL and JWT authentication. I can deliver this project within the timeline with full documentation and tests.\",\n  \"expectedRate\": 800\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 or 201', () => pm.expect([200, 201]).to.include(pm.response.code));",
            "pm.test('Proposal created with ID', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.id).to.be.a('number');",
            "  pm.collectionVariables.set('proposalId', j.id);",
            "});",
            "pm.test('Status is PENDING', () => pm.expect(pm.response.json().status).to.eql('PENDING'));"
          ]}}]
        },
        {
          "name": "Submit Duplicate Proposal (expect 400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/proposals",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{freelancerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"jobId\": {{jobId}},\n  \"coverLetter\": \"Trying to submit a duplicate proposal on the same job to test the duplicate validation rule.\",\n  \"expectedRate\": 900\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400 for duplicate proposal', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "Get Proposals for Job (Client)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/proposals/job/{{jobId}}", "host": ["{{baseUrl}}"], "path": ["proposals", "job", "{{jobId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));",
            "pm.test('At least one proposal', () => pm.expect(pm.response.json().length).to.be.at.least(1));"
          ]}}]
        },
        {
          "name": "Accept Proposal (Client)",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/proposals/{{proposalId}}/status", "host": ["{{baseUrl}}"], "path": ["proposals", "{{proposalId}}", "status"] },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clientToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"ACCEPTED\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Save project ID if returned', () => {",
            "  const j = pm.response.json();",
            "  if (j && j.projectId) pm.collectionVariables.set('projectId', j.projectId);",
            "  if (j && j.id) pm.collectionVariables.set('projectId', j.id);",
            "});"
          ]}}]
        }
      ]
    },

